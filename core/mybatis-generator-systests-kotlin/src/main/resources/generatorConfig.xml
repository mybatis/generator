    <clientGenerator targetPackage="mbg.test.mb3.generated.dsql.kotlin.miscellaneous.mapper"  targetProject="MAVEN">
      <property name="useSnakeCaseIdentifiers" value="true"/>
    </clientGenerator>

    <table tableName="PKFields" domainObjectName="MyObject" alias="A" >
      <ignoreColumn column="fred" />
