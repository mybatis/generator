    <jdbcConnection driverClass="org.hsqldb.jdbcDriver"
        connectionURL="jdbc:hsqldb:mem:aname"
        userId="sa" />

    <modelGenerator targetPackage="mbg.test.mb3.generated.dsql.kotlin.miscellaneous.model" targetProject="MAVEN">
